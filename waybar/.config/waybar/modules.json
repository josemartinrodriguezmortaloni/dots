{
  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{}",
    "format-icons": {
      "urgent": "",
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
      "*": 5
    }
  },
  "custom/updates-icon": {
    "format": "´å▓ ",
    "tooltip-format": "Paquetes a actualizar",
    "on-click": "ghostty --class=local.floating -e sudo pacman -Syu"
  },
  "custom/updates": {
    "format": "{}",
    "escape": true,
    "return-type": "text",
    "exec": "checkupdates | wc -l",
    "interval": 1800,
    "signal": 1,
    "hide-empty-text": false,
    "on-click": "ghostty --class=local.floating -e sudo pacman -Syu"
  },
  "custom/hypridle": {
    "format": "´Çú",
    "return-type": "json",
    "escape": true,
    "exec-on-event": true,
    "interval": 60,
    "exec": "hypridle-toggle status",
    "on-click": "hypridle-toggle toggle"
  },
  "custom/music": {
    "format": "´Çü  {}",
    "escape": true,
    "interval": 5,
    "tooltip": false,
    "exec": "playerctl metadata --format='{{ title }} - {{artist}}'",
    "on-click": "playerctl play-pause",
    "max-length": 50
  },
  "custom/exit": {
    "format": "´Çæ",
    "tooltip-format": "Exit menu",
    "on-click": "walker --theme menus -m menus:system --width 150 --minheight 1 --maxheight 600"
  },
  "clock": {
    "format": "{:%A %I:%M %p}",
    "format-alt": "{:%d %B %Y}",
    "tooltip": false
  },
  "cpu": {
    "interval": 5,
    "format": "´ïø",
    "on-click": "ghostty -e btop"
  },
  "pulseaudio": {
    "scroll-step": 1,
    "format": "{icon}",
    "on-click": "ghostty --class=local.wiremix -e wiremix",
    "on-click-right": "pamixer -t",
    "tooltip-format": "Playing at {volume}%",
    "format-muted": "¯╗¿",
    "format-icons": {
      "default": ["´ÇĞ", "´Çğ", "´Ç¿ "]
    }
  },
  "bluetooth": {
    "format": "´èô",
    "format-disabled": "¾░é▓",
    "format-connected": "´èö",
    "tooltip-format": "Devices connected: {num_connections}",
    "on-click": "ghostty --class=local.bluetui -e bluetui"
  },
  "battery": {
    "format": "{capacity}% {icon}",
    "format-discharging": "{capacity}% {icon}",
    "format-charging": "{capacity}% ´çĞ",
    "format-plugged": "´çĞ",
    "format-icons": {
      "charging": ["¾░ó£", "¾░éå", "¾░éç", "¾░éê", "¾░óØ", "¾░éë", "¾░óŞ", "¾░éè", "¾░éï", "¾░éà"],
      "default": ["¾░ü║", "¾░ü╗", "¾░ü╝", "¾░ü¢", "¾░ü¥", "¾░ü┐", "¾░éÇ", "¾░éü", "¾░éé", "¾░ü╣"]
    },
    "format-full": "¾░éà",
    "tooltip-format-discharging": "{power:>1.0f}WÔåô {capacity}%",
    "tooltip-format-charging": "{power:>1.0f}WÔåæ {capacity}%",
    "on-click": "power-profile --select",
    "interval": 5,
    "states": {
      "warning": 20,
      "critical": 10
    }
  },
  "network": {
    "format-icons": ["¾░ñ»", "¾░ñş", "¾░ñó", "¾░ñÑ", "¾░ñ¿"],
    "format": "{icon}",
    "format-wifi": "{icon}",
    "format-ethernet": "¾░Çé",
    "format-disconnected": "¾░ñ«",
    "tooltip-format-wifi": "{essid} ({frequency} GHz)\nÔçú{bandwidthDownBytes}  Ôçí{bandwidthUpBytes}",
    "tooltip-format-ethernet": "Ôçú{bandwidthDownBytes}  Ôçí{bandwidthUpBytes}",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 3,
    "spacing": 1,
    "on-click": "omarchy-launch-wifi"
  },
  "custom/filemanager": {
    "format": "´ü╝",
    "on-click": "nautilus",
    "tooltip-format": "Open Filemanager"
  },
  "custom/cava": {
    "exec": "~/.config/waybar/bin/waybar-cava",
    "format": "{}",
    "restart-interval": 1
  },
  "custom/cpucat": {
    "exec": "~/mydots/waybar/.config/waybar/scripts/catloop",
    "spacing": 1,
    "format": "{}",
    "tooltip": true
  }
}
